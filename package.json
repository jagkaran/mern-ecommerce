{
  "name": "ecommerce",
  "version": "1.0.0",
  "description": "",
  "main": "backend/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "start": "node backend/server.js",
    "predev": "lsof -ti :10000 | xargs kill -9 || true",
    "dev": "nodemon backend/server.js",
    "build": "cd frontend && npm install && npm run build",
    "heroku-postbuild": "cd frontend && npm install && npm run build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=list"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/backend/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/backend/__tests__/setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/backend/__tests__/dbSetup.js"
    ],
    "globalSetup": "<rootDir>/backend/__tests__/globalSetup.js",
    "globalTeardown": "<rootDir>/backend/__tests__/globalTeardown.js",
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/node_modules/**",
      "!backend/__tests__/**",
      "!backend/server.js",
      "!backend/seeder.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 45,
        "functions": 55,
        "lines": 70
      }
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.3.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "node-cache": "^5.1.2",
    "nodemon": "^3.1.9",
    "stripe": "^17.7.0",
    "validator": "^13.12.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
        "form-data": "^4.0.0",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.18.0",
        "form-data": "^4.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemailer": "^9.0.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  }
}
