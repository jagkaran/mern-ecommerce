{
  "name": "ecommerce",
  "version": "1.0.0",
  "description": "",
  "main": "backend/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "start": "node backend/server.js",
    "predev": "lsof -ti :5001 | xargs kill -9 || true",
    "dev": "nodemon backend/server.js",
    "build": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "heroku-postbuild": "cd frontend && npm install && npm run build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=list",
    "perf": "node scripts/lhci/local-lighthouse.mjs"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/backend/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/backend/__tests__/setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/backend/__tests__/dbSetup.js"
    ],
    "globalSetup": "<rootDir>/backend/__tests__/globalSetup.js",
    "globalTeardown": "<rootDir>/backend/__tests__/globalTeardown.js",
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/node_modules/**",
      "!backend/__tests__/**",
      "!backend/server.js",
      "!backend/seeder.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 45,
        "functions": 55,
        "lines": 70
      },
      "./backend/utils/pricing.js": {
        "statements": 85,
        "branches": 80,
        "functions": 85,
        "lines": 85
      },
      "./backend/services/couponService.js": {
        "statements": 85,
        "branches": 80,
        "functions": 85,
        "lines": 85
      },
      "./backend/services/paymentService.js": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      },
      "./backend/services/orderService.js": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.3.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.6.0",
    "express-validator": "^7.3.2",
    "express-xss-sanitizer": "^2.0.2",
    "form-data": "^4.0.6",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.4",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.3",
    "nodemon": "^3.1.9",
    "stripe": "^22.3.2",
    "validator": "^13.12.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "chrome-launcher": "^1.1.2",
    "eslint": "^10.7.0",
    "form-data": "^4.0.6",
    "jest": "^30.4.2",
    "lighthouse": "^13.4.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.9.5",
    "supertest": "^7.0.0"
  }
}
