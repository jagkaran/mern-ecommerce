# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js

# ─── Environment / Secrets (NEVER commit these) ──────────────────────────────
backend/config/config.env
.env
.env.*
!.env.example
# Note: frontend/.env follows CRA convention (defaults tracked, .env.local ignored).
# See frontend/.gitignore for frontend-specific env rules.

# ─── Build output ─────────────────────────────────────────────────────────────
frontend/build/
build/
dist/

# ─── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
frontend/coverage/
test-results/
playwright-report/
.playwright-mcp/
# Temp file written by MongoMemoryServer bridge between Jest processes
backend/__tests__/.mongo-uri

# E2E analysis docs (local only)
E2E_FAILURES_ANALYSIS.md
E2E_FIX_PLAN.md

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.Thumbs.db
.vscode/
.idea/
.claude/
*.swp
*.swo

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
# TypeScript incremental build cache
*.tsbuildinfo
# ESLint cache
.eslintcache
**/.eslintcache
# Lighthouse CI cache / reports
.lighthouseci/
lighthouse-report*.json
# SDD scratch ledger (task briefs, reports, review diffs)
.superpowers/sdd/
graphify-out/
